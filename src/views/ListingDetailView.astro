---
import { Image, getImage } from 'astro:assets';
import Base from '../layouts/Base.astro';
import CtaBand from '../components/CtaBand.astro';
import { listingImage } from '../lib/listing-images';
import { listingJsonLd } from '../lib/schema-org';
import { agent } from '../data/agent';
import { route, listingUrl } from '../i18n/routes';
import { useT, formatPrice, type Lang } from '../i18n';
import type { Listing } from '../lib/listings';

interface Props {
  listing: Listing;
  lang: Lang;
}
const { listing, lang } = Astro.props;
const t = useT(lang);
const d = t.listings.detail;

const title = listing.title[lang];
const isDone = listing.status === 'sold' || listing.status === 'rented';
const statusLabel =
  listing.status === 'sold'
    ? t.listings.sold
    : listing.status === 'rented'
      ? t.listings.rented
      : listing.status === 'reserved'
        ? t.listings.reserved
        : d.statusActive;

const priceLabel = listing.price.amount
  ? formatPrice(listing.price.amount, lang) +
    (listing.price.period === 'month' ? ` ${t.listings.perMonth}` : '')
  : isDone
    ? statusLabel
    : t.listings.priceOnRequest;

// resolve all images: optimized full-size URL (lightbox) + thumbnails
const resolved = [];
for (const path of listing.images) {
  const mod = listingImage(path);
  if (!mod) continue;
  const meta = (await mod()).default;
  const full = await getImage({ src: meta, width: 1600, format: 'webp' });
  resolved.push({ meta, fullSrc: full.src });
}

const descriptionShown = (lang === 'en' && listing.description.en) || listing.description.cs;
const isMachineTranslated = lang === 'en' && !!listing.description.en;
const isCzechFallback = lang === 'en' && !listing.description.en;
const paragraphs = descriptionShown.split(/\n+/).filter(Boolean);

const facts: [string, string][] = [
  [d.ref, listing.ref],
  ...(listing.disposition ? [[d.disposition, listing.disposition] as [string, string]] : []),
  ...(listing.areaM2 ? [[d.area, `${listing.areaM2} m²`] as [string, string]] : []),
  ...(listing.landAreaM2
    ? [
        [
          d.landArea,
          `${new Intl.NumberFormat(lang === 'cs' ? 'cs-CZ' : 'en-GB').format(listing.landAreaM2)} m²`,
        ] as [string, string],
      ]
    : []),
  [d.location, [listing.location.municipality, listing.location.region].filter(Boolean).join(', ')],
  [d.price, priceLabel],
  [d.status, statusLabel],
];

const pageUrl = `${Astro.site!.origin}${listingUrl(listing.slug, lang)}`;
const jsonLd = [
  listingJsonLd(
    listing,
    lang,
    pageUrl,
    resolved.slice(0, 5).map((r) => `${Astro.site!.origin}${r.fullSrc}`),
  ),
];
---

<Base
  lang={lang}
  title={`${title}${t.meta.titleSuffix}`}
  description={listing.description.cs.slice(0, 155)}
  ogImage={resolved[0]?.fullSrc}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-[1200px] px-5 py-10 md:px-8">
    <nav class="microlabel text-ink-soft">
      <a href={route('listings', lang)} class="link-signal">← {d.backToListings}</a>
    </nav>

    <header class="mt-6 flex flex-wrap items-start justify-between gap-4">
      <div>
        <h1 class="max-w-3xl text-h2 font-display font-extrabold">{title}</h1>
        <p class="microlabel mt-3 text-ink-soft">
          {listing.location.municipality} · {listing.location.region} · {d.ref}
          {listing.ref}
        </p>
      </div>
      <p class="font-display text-3xl font-extrabold whitespace-nowrap">
        {isDone ? <span class="text-signal">{statusLabel}</span> : priceLabel}
      </p>
    </header>

    <!-- GALLERY -->
    {
      resolved.length > 0 && (
        <div class="mt-8" id="gallery" aria-label={d.gallery}>
          <div class="grid gap-3 md:grid-cols-[2fr_1fr]">
            <button
              type="button"
              class="gallery-open group relative block cursor-zoom-in border border-ink"
              data-index="0"
            >
              <Image
                src={resolved[0]!.meta}
                alt={`${d.photoOf} ${title} — 1`}
                widths={[480, 760, 1080, 1400]}
                sizes="(min-width: 768px) 66vw, 100vw"
                class:list={[
                  'aspect-[4/3] h-full w-full object-cover',
                  isDone && 'grayscale-[0.35]',
                ]}
                loading="eager"
                fetchpriority="high"
              />
              {isDone && (
                <span class="microlabel absolute top-0 left-0 bg-signal px-4 py-2 text-paper">
                  {statusLabel}
                </span>
              )}
            </button>
            <div class="grid grid-cols-2 gap-3 md:grid-cols-1 md:grid-rows-2">
              {resolved.slice(1, 3).map((img, i) => (
                <button
                  type="button"
                  class="gallery-open block cursor-zoom-in border border-ink"
                  data-index={String(i + 1)}
                >
                  <Image
                    src={img.meta}
                    alt={`${d.photoOf} ${title} — ${i + 2}`}
                    widths={[400, 640]}
                    sizes="(min-width: 768px) 33vw, 50vw"
                    class="aspect-[4/3] h-full w-full object-cover"
                    loading="lazy"
                  />
                </button>
              ))}
            </div>
          </div>
          {resolved.length > 3 && (
            <div class="mt-3 grid grid-cols-4 gap-3 md:grid-cols-6">
              {resolved.slice(3).map((img, i) => (
                <button
                  type="button"
                  class="gallery-open block cursor-zoom-in border border-ink"
                  data-index={String(i + 3)}
                >
                  <Image
                    src={img.meta}
                    alt={`${d.photoOf} ${title} — ${i + 4}`}
                    widths={[240, 400]}
                    sizes="(min-width: 768px) 16vw, 25vw"
                    class="aspect-[4/3] h-full w-full object-cover"
                    loading="lazy"
                  />
                </button>
              ))}
            </div>
          )}
        </div>
      )
    }

    <div class="mt-12 grid gap-12 lg:grid-cols-[1.2fr_0.8fr]">
      <!-- DESCRIPTION -->
      <div>
        <h2 class="microlabel text-ink-soft">{d.description}</h2>
        {
          isCzechFallback && (
            <p class="mt-4 border-l-2 border-signal bg-mist p-4 text-sm">
              Full description is available in Czech below — happy to walk you through the details
              in English, just{' '}
              <a href={route('contact', lang)} class="link-signal font-medium">
                get in touch
              </a>
              .
            </p>
          )
        }
        <div class="mt-4 space-y-4 leading-relaxed">
          {
            paragraphs.map((p, i) =>
              i === 0 ? <p class="font-display text-xl font-bold">{p}</p> : <p>{p}</p>,
            )
          }
        </div>
        {
          isMachineTranslated && (
            <p class="microlabel mt-6 text-ink-soft">
              Automatic translation — Czech original on{' '}
              <a
                href={listing.sourceUrl}
                class="link-signal"
                target="_blank"
                rel="noopener noreferrer"
              >
                remax-czech.cz
              </a>
            </p>
          )
        }
      </div>

      <!-- FACTS + CTA -->
      <aside>
        <h2 class="microlabel text-ink-soft">{d.facts}</h2>
        <dl class="mt-4">
          {
            facts.map(([label, value]) => (
              <div class="hairline-t flex items-baseline justify-between gap-6 py-3 last:border-b last:border-ink">
                <dt class="text-sm text-ink-soft">{label}</dt>
                <dd class="text-right font-display font-bold">{value}</dd>
              </div>
            ))
          }
        </dl>

        {
          !isDone && (
            <div class="mt-8 border border-ink p-6">
              <h2 class="font-display text-xl font-bold">{d.interested}</h2>
              <p class="mt-2 text-sm leading-relaxed text-ink-soft">
                {d.interestedText}{' '}
                <a href={agent.phoneHref} class="link-signal font-bold whitespace-nowrap">
                  {agent.phone}
                </a>
              </p>
              <a
                href={`${route('contact', lang)}?ref=${encodeURIComponent(listing.ref)}`}
                class="microlabel mt-5 inline-block bg-signal px-7 py-3.5 text-paper transition-colors hover:bg-signal-deep"
              >
                {d.cta}
              </a>
            </div>
          )
        }

        <p class="mt-6">
          <a
            href={listing.sourceUrl}
            class="link-signal microlabel text-ink-soft"
            target="_blank"
            rel="noopener noreferrer"
          >
            {d.source}
            <span aria-hidden="true">↗</span>
          </a>
        </p>
      </aside>
    </div>
  </article>

  <!-- LIGHTBOX -->
  <dialog
    id="lightbox"
    class="m-auto w-full max-w-5xl border-0 bg-transparent p-4 backdrop:bg-ink/90"
    data-images={JSON.stringify(resolved.map((r) => r.fullSrc))}
  >
    <div class="relative">
      <img id="lightbox-img" src="" alt={title} class="max-h-[85vh] w-full object-contain" />
      <div class="mt-3 flex items-center justify-between">
        <button
          type="button"
          id="lightbox-prev"
          class="microlabel border border-paper px-5 py-2.5 text-paper hover:bg-signal hover:border-signal"
          aria-label="Previous photo"
        >
          ←
        </button>
        <span id="lightbox-counter" class="microlabel text-paper"></span>
        <button
          type="button"
          id="lightbox-next"
          class="microlabel border border-paper px-5 py-2.5 text-paper hover:bg-signal hover:border-signal"
          aria-label="Next photo"
        >
          →
        </button>
        <button
          type="button"
          id="lightbox-close"
          class="microlabel border border-paper px-5 py-2.5 text-paper hover:bg-signal hover:border-signal"
        >
          ✕
        </button>
      </div>
    </div>
  </dialog>

  <script>
    const dialog = document.getElementById('lightbox') as HTMLDialogElement | null;
    if (dialog) {
      const images: string[] = JSON.parse(dialog.dataset.images || '[]');
      const img = document.getElementById('lightbox-img') as HTMLImageElement;
      const counter = document.getElementById('lightbox-counter')!;
      let index = 0;

      const show = (i: number) => {
        index = (i + images.length) % images.length;
        img.src = images[index]!;
        counter.textContent = `${index + 1} / ${images.length}`;
      };

      document.querySelectorAll<HTMLButtonElement>('.gallery-open').forEach((btn) => {
        btn.addEventListener('click', () => {
          show(Number(btn.dataset.index || 0));
          dialog.showModal();
        });
      });
      document.getElementById('lightbox-prev')!.addEventListener('click', () => show(index - 1));
      document.getElementById('lightbox-next')!.addEventListener('click', () => show(index + 1));
      document.getElementById('lightbox-close')!.addEventListener('click', () => dialog.close());
      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) dialog.close();
      });
      dialog.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') show(index - 1);
        if (e.key === 'ArrowRight') show(index + 1);
      });
    }
  </script>

  <CtaBand lang={lang} />
</Base>
