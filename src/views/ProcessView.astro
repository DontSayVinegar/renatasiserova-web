---
import Base from '../layouts/Base.astro';
import CtaBand from '../components/CtaBand.astro';
import { useT, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useT(lang);
---

<Base lang={lang} title={`${t.process.title}${t.meta.titleSuffix}`} description={t.process.intro}>
  <section class="mx-auto max-w-[1200px] px-5 py-14 md:px-8">
    <h1 class="text-h1 font-display font-extrabold">{t.process.title}</h1>
    <p class="mt-4 max-w-2xl text-lg text-ink-soft">{t.process.intro}</p>

    <ol class="mt-14">
      {
        t.process.steps.map((step, i) => (
          <li class="hairline-t grid gap-4 py-10 md:grid-cols-[120px_1fr] md:gap-10 last:border-b last:border-ink">
            <span
              class="font-display text-6xl font-extrabold text-signal md:text-7xl"
              aria-hidden="true"
            >
              0{i + 1}
            </span>
            <div>
              <h2 class="font-display text-2xl font-bold">{step.title}</h2>
              <p class="mt-3 max-w-2xl leading-relaxed text-ink-soft">{step.text}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="bg-mist py-20">
    <div class="mx-auto max-w-[1200px] px-5 md:px-8">
      <h2 class="text-h2 font-display font-extrabold">{t.process.faqTitle}</h2>
      <div class="mt-8 max-w-3xl">
        {
          t.process.faq.map((item) => (
            <details class="group hairline-t py-1 last:border-b last:border-ink">
              <summary class="flex cursor-pointer list-none items-baseline justify-between gap-6 py-4 font-display text-lg font-bold select-none [&::-webkit-details-marker]:hidden">
                {item.q}
                <span
                  class="text-signal transition-transform duration-200 group-open:rotate-45"
                  aria-hidden="true"
                >
                  +
                </span>
              </summary>
              <p class="max-w-2xl pb-6 leading-relaxed text-ink-soft">{item.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand lang={lang} title={t.process.cta} />
</Base>
