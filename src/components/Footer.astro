---
import { agent } from '../data/agent';
import { route } from '../i18n/routes';
import { useT, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useT(lang);
const year = new Date().getFullYear();

const nav = [
  { href: route('listings', lang), label: t.nav.listings },
  { href: route('sold', lang), label: t.nav.sold },
  { href: route('process', lang), label: t.nav.process },
  { href: route('reviews', lang), label: t.nav.reviews },
  { href: route('about', lang), label: t.nav.about },
  { href: route('contact', lang), label: t.nav.contact },
];
---

<footer class="bg-ink text-paper">
  <div class="mx-auto max-w-[1200px] px-5 py-14 md:px-8">
    <div class="grid gap-10 md:grid-cols-[2fr_1fr_1fr]">
      <div>
        <p class="font-display text-3xl font-extrabold tracking-tight">
          Renata Šiserová<span class="text-signal">.</span>
        </p>
        <p class="mt-3 max-w-md text-paper/70">{t.footer.tagline}</p>
        <p class="mt-6">
          <a href={agent.phoneHref} class="link-signal font-display text-xl font-bold"
            >{agent.phone}</a
          >
        </p>
        <p class="mt-1">
          <a href={`mailto:${agent.email}`} class="link-signal text-paper/85">{agent.email}</a>
        </p>
      </div>

      <nav aria-label="Footer">
        <ul class="space-y-2.5">
          {
            nav.map((item) => (
              <li>
                <a href={item.href} class="link-signal text-paper/85">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="text-sm text-paper/70">
        <p class="microlabel mb-3 text-paper">{agent.office.name}</p>
        <p>{agent.office.street}</p>
        <p>{agent.office.city}</p>
        <p class="mt-4">
          {t.footer.ic}: {agent.ic}
        </p>
        <p class="mt-1">{t.footer.legal}</p>
      </div>
    </div>

    <div class="mt-12 border-t border-paper/20 pt-6 text-xs leading-relaxed text-paper/50">
      <p>{t.footer.law39}</p>
      <p>{t.footer.coi}</p>
      <p class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1">
        <span>{t.footer.copyright.replace('{year}', String(year))}</span>
        <span aria-hidden="true">·</span>
        <a href={route('privacy', lang)} class="link-signal text-paper/70">{t.footer.privacy}</a>
        <span aria-hidden="true">·</span>
        <span>{t.footer.cookies}</span>
      </p>
    </div>
  </div>
</footer>
